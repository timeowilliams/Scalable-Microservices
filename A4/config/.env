API_KEY=test-34567890
RABBITMQ_USER=admin
RABBITMQ_PASS=admin
LOG_LEVEL=info
ALLOWED_ORIGIN=http://localhost:4173

# Node command explicit backpressure controls
RATE_LIMIT_GENERAL_RPS=120
RATE_LIMIT_GENERAL_BURST=240
RATE_LIMIT_WRITE_RPS=60
RATE_LIMIT_WRITE_BURST=120
BACKPRESSURE_MAX_CONCURRENT_WRITES=16
BACKPRESSURE_MAX_PENDING_WRITES=48
BACKPRESSURE_OVERLOAD_STRATEGY=delay
BACKPRESSURE_MAX_QUEUE_WAIT_MS=2000

# Worker configuration
SENSOR_WORKERS=2
COMMAND_WORKERS=2
PYTHON_SENSOR_WORKERS=2
PYTHON_COMMAND_WORKERS=2
